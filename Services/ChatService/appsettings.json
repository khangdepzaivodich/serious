{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "RsaPublicKey": "PASTE_PUBLIC_KEY_HERE",
    "Issuer": "identity-api",
    "Audience": "identity-client"
  },
  "ConnectionStrings": {
    "MongoDb": "mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/chat_db?retryWrites=true&w=majority",
    "Redis": "<your-redis-endpoint>:<port>,password=<your-password>"
  }
}
